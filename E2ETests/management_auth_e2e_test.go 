package E2ETests

import (
	"io"
	"net/http"
	"os"
	"strings"
	"testing"
)

func TestManagementHealthWithoutTokenReturnsForbidden(t *testing.T) {
	resp, err := http.Get("http://localhost:5444/health")
	if err != nil {
		t.Fatalf("failed to call management health endpoint: %v", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusForbidden {
		body, _ := io.ReadAll(resp.Body)
		t.Fatalf("status = %d, want %d; body=%s", resp.StatusCode, http.StatusForbidden, string(body))
	}
}

func TestManagementHealthWithInvalidTokenReturnsForbidden(t *testing.T) {
	req, err := http.NewRequest(http.MethodGet, "http://localhost:5444/health", nil)
	if err != nil {
		t.Fatalf("failed to create request: %v", err)
	}
	req.Header.Set("Authorization", "Bearer invalid-token-for-e2e")

	client := &http.Client{}
	resp, err := client.Do(req)
	if err != nil {
		t.Fatalf("failed to call management health endpoint: %v", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusForbidden {
		body, _ := io.ReadAll(resp.Body)
		t.Fatalf("status = %d, want %d; body=%s", resp.StatusCode, http.StatusForbidden, string(body))
	}
}

func TestManagementHealthWithValidTokenReturnsOKWhenProvided(t *testing.T) {
	token := strings.TrimSpace(os.Getenv("SHIBUDB_E2E_MANAGEMENT_TOKEN"))
	if token == "" {
		t.Skip("set SHIBUDB_E2E_MANAGEMENT_TOKEN to run valid management-token e2e test")
	}

	req, err := http.NewRequest(http.MethodGet, "http://localhost:5444/health", nil)
	if err != nil {
		t.Fatalf("failed to create request: %v", err)
	}
	req.Header.Set("Authorization", "Bearer "+token)

	client := &http.Client{}
	resp, err := client.Do(req)
	if err != nil {
		t.Fatalf("failed to call management health endpoint: %v", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		body, _ := io.ReadAll(resp.Body)
		t.Fatalf("status = %d, want %d; body=%s", resp.StatusCode, http.StatusOK, string(body))
	}
}